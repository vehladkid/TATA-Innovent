# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Supabase Postgres connection string (ap-south-1)
# Leave blank to run without a database (events are in-memory only)
DATABASE_URL=postgresql://user:password@db.xxxx.supabase.co:5432/postgres

# Supabase project URL and service role key (backend-only persistence path)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...   # service_role secret — never expose to client

# LLM API keys — Copilot cascade: Groq Llama 3.3 → Claude → offline rule-based
GROQ_API_KEY=gsk_...                # free key at console.groq.com
ANTHROPIC_API_KEY=sk-ant-...        # optional Claude fallback

# n8n webhook for critical-event fan-out (Telegram + email)
N8N_WEBHOOK_URL=https://<n8n-host>/webhook/critical-event

# Comma-separated list of allowed CORS origins, or * for all (local dev only)
CORS_ORIGINS=*

# Python logging level
LOG_LEVEL=INFO

# development | production
ENVIRONMENT=development
